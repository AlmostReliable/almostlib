{
  "schemaVersion": 1,
  "id": "${modId}",
  "version": "${version}",
  "name": "${modName}",
  "description": "${modDescription}",
  "authors": [
    "${modAuthor}"
  ],
  "contact": {
    "homepage": "https://github.com/${githubUser}",
    "sources": "https://github.com/${githubUser}/${githubRepo}",
    "issues": "https://github.com/${githubUser}/${githubRepo}/issues"
  },
  "license": "${license}",
  "icon": "assets/universalpipeline/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.almostreliable.lib.AlmostLibFabric"
    ]
  },
  "mixins": [
    "almostlib.mixins.json",
    "almostlib-common.mixins.json"
  ],
  "accessWidener": "almostlib.accesswidener",
  "depends": {
    "fabric": "*",
    "minecraft": ">=${minecraftVersion}",
    "java": ">=17"
  }
}
